# Environment Variables for GitHub AI Task Manager
# Copy this file to .env and fill in your actual values

# GitHub API Token (Optional - without it, you'll hit rate limits)
# Get yours from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI API Key (Optional - without it, uses mock responses)
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
